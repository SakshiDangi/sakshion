{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "declaration": true,
    "sourceMap": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,

    "types": ["node", "vitest/globals"]
  },

  "include": ["src"],

  "exclude": [
    "dist",
    "node_modules"
  ]
}