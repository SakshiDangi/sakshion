{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "target": "ES2017",

    "lib": [
      "dom",
      "dom.iterable",
      "ESNext"
    ],

    "allowJs": true,

    "jsx": "react-jsx",

    "paths": {
      "@/*": [
        "./*"
      ]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],

  "exclude": [
    "node_modules"
  ]
}