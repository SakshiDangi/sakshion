{
  "$schema": "https://json.schemastore.org/tsconfig",

  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",

    "moduleResolution": "Bundler",

    "lib": [
      "ES2022"
    ],

    "strict": true,

    "incremental": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "noEmit": true,

    "baseUrl": "."
  },

  "exclude": [
    "node_modules",
    "dist",
    ".next",
    ".turbo",
    "coverage"
  ]
}